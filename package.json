{
  "name": "exambro-edu-kasuari",
  "version": "1.0.0",
  "description": "ExamBrowser EDU Timur Kasuari - Aplikasi Ujian Aman",
  "main": "main.js",
  "author": "EDU Timur Kasuari",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --publish=never",
    "build:win": "electron-builder --win --publish=never",
    "build:dir": "electron-builder --win --dir --publish=never",
    "build:linux": "electron-builder --linux --publish=never",
    "build:mac": "electron-builder --mac",
    "release": "electron-builder --win --publish always"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "publish": {
      "provider": "github",
      "owner": "MdTs121220",
      "repo": "exambroEDUKasuari",
      "private": false
    },
    "appId": "com.edutimurkasuari.exambro",
    "productName": "ExamBrowser EDU Kasuari",
    "copyright": "© 2025 EDU Timur Kasuari",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "requireAdministrator"
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ExamBrowser EDU Kasuari"
    },
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "checker.html",
      "settings.html",
      "assets/**"
    ]
  }
}
